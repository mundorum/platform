{
  "title": "OCR inside PDF",
  "imports": [],
  "components": [
    {
      "id": "ocr_1",
      "type": "pdf:ocr",
      "publish": "done~player/done",
      "subscribe": "player/start~ocr",
      "properties": {
        "deskew": true,
        "language": "eng",
        "force_ocr": true,
        "input_file": "shared:books/case-teaching-in-medicine-1906.pdf",
        "output_file": "shared:books/case-teaching-in-medicine-1906_extracted.pdf",
        "rotate_pages": true
      }
    }
  ]
}