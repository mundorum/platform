{
  "title": "New Scene",
  "imports": [
    "noid:lm_agents.lm",
    "noid:basic.console_display"
  ],
  "components": [
    {
      "type": "lm:lm-agent",
      "id": "lm_agent_1",
      "properties": {
        "model": "llama3.2:3b",
        "host": "http://localhost:11434",
        "prompt_template": "Who are you?",
        "temperature": 0.1
      },
      "publish": "output~lm/output",
      "subscribe": "player/start~input"
    },
    {
      "type": "basic:console-display",
      "id": "console_display_1",
      "properties": {
        "label": "",
        "show_topic": false,
        "pretty": true
      },
      "publish": "output~player/done",
      "subscribe": "lm/output~show"
    }
  ]
}