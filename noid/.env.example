# Shared — read by both servers
COLLECTIONS_FILE=./collections.yaml
SCENE_PACKAGES_DIR=./storage/scene_packages
SHARED_RESOURCES_DIR=./storage/shared_resources

# Host ports published by docker-compose.yml (override to avoid clashes with other stacks)
AUTHORING_PORT=8000
PROCESSING_PORT=8001

# Django — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-key-change-in-production
# Must be "false" in production
DEBUG=true
# Comma-separated list of hostnames Django will answer to (e.g. mundorum.ic.unicamp.br)
ALLOWED_HOSTS=*

# Postgres credentials (must match DATABASE_URL below)
POSTGRES_USER=noid
POSTGRES_PASSWORD=noid
POSTGRES_DB=noid

# Authoring Machine (Django) — copy these to authoring/.env when that server is built
DATABASE_URL=postgres://noid:noid@db:5432/noid
PROCESSING_URL=http://localhost:8001
PROCESSING_API_KEY=dev-key-change-in-prod

# Google OAuth (authoring only)
# Obtain GOOGLE_CLIENT_ID from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# CORS: comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:8000

# Seed: email that gets a manager pre-authorization on first deploy
# Run after migrate: python manage.py seed_initial_manager
INITIAL_MANAGER_EMAIL=your-admin@example.com

# Processing Machine (FastAPI)
PROCESSING_API_KEY=dev-key-change-in-prod
SCENES_DIR=/tmp/noid_processing
